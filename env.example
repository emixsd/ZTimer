# Zendesk
ZENDESK_SUBDOMAIN=suaempresa
ZENDESK_EMAIL=voce@suaempresa.com
ZENDESK_API_TOKEN=seu_token_de_api
WEBHOOK_SECRET=

# ID do campo Decimal criado no Zendesk onde a duração será gravada
ZENDESK_CUSTOM_FIELD_ID=

# Fluxo alvo: Seguro Viagem/N2
TARGET_TICKET_FORM_IDS=52281638323859

# Campo lista suspensa do país no ticket
COUNTRY_CUSTOM_FIELD_ID=44008169716755

# Vazio = conta todo o tempo em pending. Preencha (ex.: aguard_retorno_cliente)
# para contar só quando uma dessas tags estiver ativa.
RESPONSE_PENDING_TAGS=

# Modo: base_status (Pendente padrão) ou custom_status
MEASURE_MODE=base_status
# Usado só no modo custom_status:
TARGET_STATUS_LABELS=Pendente Prestador,Em Organização

# Unidade gravada no campo: minutes ou hours
FIELD_UNIT=minutes

# Banco (log de auditoria local)
DATABASE_URL=sqlite:///metrics.db

# Busca padrão do Zendesk para POST /sync sem corpo
DEFAULT_SYNC_QUERY=type:ticket

# Varredura automática dos tickets pendentes para enviar notas internas vencidas
PENDING_TIMER_LOOP_ENABLED=true
PENDING_TIMER_LOOP_INTERVAL_SECONDS=300
PENDING_TIMER_SYNC_QUERY=type:ticket status:pending tags:tmr_pendente_armado
PENDING_SLA_MINUTES=60

# Exportação para Excel/Power Query
EXPORT_DIR=exports
RESPONSE_EXPORT_FILENAME=respostas_solicitantes.csv

# Relatório diário por e-mail + retenção de 24h
# Envia o CSV por e-mail no horário configurado e apaga os registros
# resolvidos com mais de RETENTION_HOURS (tickets em pending ficam).
REPORT_EMAIL_ENABLED=false
REPORT_EMAIL_TO=
REPORT_SEND_HOUR=18
REPORT_TIMEZONE=America/Sao_Paulo
RETENTION_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Servidor local
FLASK_DEBUG=false
